generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enum definitions
enum UserRole {
  warga
  staff
  kepling
  lurah
  sekertaris
  admin
}

enum UserStatus {
  active
  inactive
  banned
}

enum JenisKelamin {
  L
  P
}

enum GolonganDarah {
  A
  B
  AB
  O
  TIDAK_DIKETAHUI @map("-")
}

enum StatusKawin {
  BELUM_KAWIN  @map("Belum Kawin")
  KAWIN        @map("Kawin")
  CERAI_HIDUP  @map("Cerai Hidup")
  CERAI_MATI   @map("Cerai Mati")
}

// Users table
model User {
  id          BigInt      @id @default(autoincrement()) @db.BigInt
  nik         String?     @unique @db.Char(16)
  nama        String      @db.VarChar(100)
  noHp        String      @unique @map("no_hp") @db.VarChar(20)
  role        UserRole    @default(warga)
  password    String      @db.VarChar(255)
  isValidate  Boolean     @default(false) @map("is_validate")
  status      UserStatus  @default(active)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Relations
  tokens      UserToken[]
  kependudukan DataKependudukan? @relation(fields: [nik], references: [nik])
  validateRequests       ValidateRequest[] @relation("UserValidateRequests")
  processedValidateRequests ValidateRequest[] @relation("AdminProcessedRequests")
  lingkunganKepling LingkunganKepling[]
  submissions    Submission[]
  approvals      SubmissionApproval[]
  lurahProfiles  LurahProfile[]
  sekertarisProfile SekertarisProfile?
  notifications  Notification[]
  arsipSurat     ArsipSurat[]

  @@map("users")
}

// User tokens table for refresh tokens
model UserToken {
  id           BigInt   @id @default(autoincrement()) @db.BigInt
  userId       BigInt   @map("user_id") @db.BigInt
  refreshToken String   @map("refresh_token") @db.Text
  userAgent    String?  @map("user_agent") @db.VarChar(255)
  ipAddress    String?  @map("ip_address") @db.VarChar(50)
  expiredAt    DateTime @map("expired_at")
  createdAt    DateTime @default(now()) @map("created_at")
  fcmToken     String?  @map("fcm_token") @db.VarChar(255)

  // Relations
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_tokens")
}

// Lingkungan table - environment/neighborhood divisions
model Lingkungan {
  id          BigInt   @id @default(autoincrement()) @db.BigInt
  nama        String   @db.VarChar(100)
  kode        String?  @unique @db.VarChar(10)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  keplings    LingkunganKepling[]
  kependudukan DataKependudukan[]
  submissions Submission[]

  @@map("lingkungan")
}

// Lingkungan Kepling table - assigns kepling role users to environments
model LingkunganKepling {
  id            BigInt    @id @default(autoincrement()) @db.BigInt
  lingkunganId  BigInt    @map("lingkungan_id") @db.BigInt
  userId        BigInt    @map("user_id") @db.BigInt
  mulai         DateTime  @db.Date
  selesai       DateTime? @db.Date
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  lingkungan    Lingkungan @relation(fields: [lingkunganId], references: [id], onDelete: Cascade)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("lingkungan_kepling")
}

// Data kependudukan table
model DataKependudukan {
  nik             String       @id @db.Char(16)
  nama            String       @db.VarChar(100)
  tempatLahir     String       @map("tempat_lahir") @db.VarChar(100)
  tanggalLahir    DateTime     @map("tanggal_lahir") @db.Date
  jenisKelamin    JenisKelamin @map("jenis_kelamin")
  golonganDarah   GolonganDarah? @map("golongan_darah")

  alamat          String       @db.Text
  rt              String?      @db.Char(3)
  rw              String?      @db.Char(3)
  lingkunganId    BigInt?      @map("lingkungan_id") @db.BigInt
  kelurahan       String       @db.VarChar(100)
  kecamatan       String       @db.VarChar(100)
  kabupatenKota   String       @map("kabupaten_kota") @db.VarChar(100)
  provinsi        String       @db.VarChar(100)

  statusKawin     StatusKawin  @map("status_kawin")
  agama           String       @db.VarChar(50)
  pekerjaan       String       @db.VarChar(100)
  kewarganegaraan String       @default("WNI") @db.VarChar(10)

  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  // Relations
  user            User?
  validateRequests ValidateRequest[]
  lingkungan      Lingkungan?  @relation(fields: [lingkunganId], references: [id])

  @@map("data_kependudukan")
}

// Enum for validate request status
enum ValidateRequestStatus {
  pending
  approved
  rejected
}

enum ValidateRequestType {
  existing_data
  submitted_data
}

// Validate request table
model ValidateRequest {
  id              BigInt               @id @default(autoincrement()) @db.BigInt
  userId          BigInt               @map("user_id") @db.BigInt
  nik             String?              @db.Char(16)
  requestType     ValidateRequestType  @default(existing_data) @map("request_type")
  submittedData   Json?                @map("submitted_data")
  status          ValidateRequestStatus @default(pending)
  adminNotes      String?              @map("admin_notes") @db.Text
  processedBy     BigInt?              @map("processed_by") @db.BigInt
  processedAt     DateTime?            @map("processed_at")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  // Relations
  user            User                 @relation("UserValidateRequests", fields: [userId], references: [id], onDelete: Cascade)
  admin           User?                @relation("AdminProcessedRequests", fields: [processedBy], references: [id])
  kependudukan    DataKependudukan?    @relation(fields: [nik], references: [nik])

  @@map("validate_requests")
}

// ==================== SUBMISSION WORKFLOW ====================

// Enum for submission types
enum SubmissionType {
  domisili
  usaha
  keramaian
  belum_menikah
  keterangan_hilang
  penghasilan
  skck
  tidak_mampu
}

// Enum for submission status
enum SubmissionStatus {
  pending_kepling
  pending_lurah
  rejected
  approved
  issued
}

// Enum for approval stage
enum ApprovalStage {
  kepling
  lurah
}

// Enum for approval status
enum ApprovalStatus {
  approved
  rejected
}

// Submissions table - core entity for letter requests
model Submission {
  id            BigInt           @id @default(autoincrement()) @db.BigInt
  userId        BigInt           @map("user_id") @db.BigInt
  lingkunganId  BigInt           @map("lingkungan_id") @db.BigInt
  type          SubmissionType
  status        SubmissionStatus @default(pending_kepling)
  payload       Json?            @db.Json
  rejectReason  String?          @map("reject_reason") @db.Text
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  // Relations
  user          User             @relation(fields: [userId], references: [id])
  lingkungan    Lingkungan       @relation(fields: [lingkunganId], references: [id])
  documents     SubmissionDocument[]
  approvals     SubmissionApproval[]
  issuedLetter  IssuedLetter?
  signingSessions SigningSession[]

  @@map("submissions")
}

// Submission documents table - attachments for submissions
model SubmissionDocument {
  id            BigInt     @id @default(autoincrement()) @db.BigInt
  submissionId  BigInt     @map("submission_id") @db.BigInt
  filePath      String     @map("file_path") @db.VarChar(255)
  fileType      String?    @map("file_type") @db.VarChar(50)
  description   String?    @db.VarChar(100)
  verified      Boolean    @default(false)
  createdAt     DateTime   @default(now()) @map("created_at")

  // Relations
  submission    Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("submission_documents")
}

// Submission approvals table - audit trail for approvals
model SubmissionApproval {
  id            BigInt         @id @default(autoincrement()) @db.BigInt
  submissionId  BigInt         @map("submission_id") @db.BigInt
  approvedBy    BigInt         @map("approved_by") @db.BigInt
  stage         ApprovalStage
  status        ApprovalStatus
  note          String?        @db.Text
  createdAt     DateTime       @default(now()) @map("created_at")

  // Relations
  submission    Submission     @relation(fields: [submissionId], references: [id])
  approver      User           @relation(fields: [approvedBy], references: [id])

  @@map("submission_approvals")
}

// ==================== LETTER ISSUANCE ====================

// Lurah profile - stores Lurah-specific information (NIP, etc.)
model LurahProfile {
  id            BigInt    @id @default(autoincrement()) @db.BigInt
  userId        BigInt    @map("user_id") @db.BigInt
  nip           String    @db.VarChar(18) // NIP format: 18 digits
  namaLengkap   String    @map("nama_lengkap") @db.VarChar(100)
  jabatan       String    @default("Lurah") @db.VarChar(100)
  pangkat       String?   @db.VarChar(100) // Golongan/Pangkat
  mulaiMenjabat DateTime  @map("mulai_menjabat") @db.Date
  akhirMenjabat DateTime? @map("akhir_menjabat") @db.Date
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lurahKeys     LurahKey[]
  signingSessions SigningSession[]

  @@index([userId])
  @@index([nip])

  @@map("lurah_profiles")
}

// Sekertaris profile - stores Sekertaris-specific information (NIP, etc.)
model SekertarisProfile {
  id            BigInt    @id @default(autoincrement()) @db.BigInt
  userId        BigInt    @unique @map("user_id") @db.BigInt
  nip           String    @unique @db.VarChar(18) // NIP format: 18 digits
  namaLengkap   String    @map("nama_lengkap") @db.VarChar(100)
  jabatan       String    @default("Sekertaris") @db.VarChar(100)
  pangkat       String?   @db.VarChar(100) // Golongan/Pangkat
  mulaiMenjabat DateTime  @map("mulai_menjabat") @db.Date
  akhirMenjabat DateTime? @map("akhir_menjabat") @db.Date
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sekertaris_profiles")
}

// Key status enum for lurah key lifecycle
enum KeyStatus {
  ACTIVE
  REVOKED
  INACTIVE
}

enum SigningSessionStatus {
  PENDING
  COMPLETED
  EXPIRED
  REJECTED
}

// Lurah key pairs for digital signatures
model LurahKey {
  id                  BigInt        @id @default(autoincrement()) @db.BigInt
  lurahProfileId      BigInt        @map("lurah_profile_id") @db.BigInt
  publicKey           String        @map("public_key") @db.Text
  algorithm           String        @default("RSA-SHA256") @db.VarChar(50)
  status              KeyStatus     @default(ACTIVE)

  // v2.0 mobile-key / PAdES certificate metadata. Private keys are not stored for new keys.
  certificatePem      String?       @map("certificate_pem") @db.Text
  serialNumber        String?       @unique @map("serial_number") @db.VarChar(64)
  fingerprint         String?       @unique @db.VarChar(128)
  deviceLabel         String?       @map("device_label") @db.VarChar(255)
  enrolledAt          DateTime?     @map("enrolled_at")
  expiresAt           DateTime?     @map("expires_at")

  // Deactivation tracking
  deactivatedAt       DateTime?     @map("deactivated_at")
  deactivatedById     BigInt?       @map("deactivated_by_id") @db.BigInt
  deactivateReason    String?       @map("deactivate_reason") @db.Text

  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  // Relations
  lurahProfile        LurahProfile  @relation(fields: [lurahProfileId], references: [id], onDelete: Cascade)
  signingSessions     SigningSession[]
  issuedLetters       IssuedLetter[] @relation("IssuedLetterSignatureKey")

  @@index([status])
  @@index([lurahProfileId])
  @@index([fingerprint])
  @@map("lurah_keys")
}

model SigningSession {
  id                 BigInt               @id @default(autoincrement()) @db.BigInt
  submissionId       BigInt               @map("submission_id") @db.BigInt
  lurahProfileId     BigInt               @map("lurah_profile_id") @db.BigInt
  keyId              BigInt               @map("key_id") @db.BigInt
  bytesToSignBase64  String               @map("bytes_to_sign_base64") @db.Text
  pdfDraftPath       String               @map("pdf_draft_path") @db.VarChar(255)
  letterNumber       String               @map("letter_number") @db.VarChar(100)
  verificationCode   String               @map("verification_code") @db.VarChar(50)
  issuedDate         DateTime             @map("issued_date")
  expiresAt          DateTime             @map("expires_at")
  status             SigningSessionStatus @default(PENDING)
  completedAt        DateTime?            @map("completed_at")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  submission         Submission           @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  lurahProfile       LurahProfile         @relation(fields: [lurahProfileId], references: [id], onDelete: Cascade)
  lurahKey           LurahKey             @relation(fields: [keyId], references: [id])

  @@index([submissionId])
  @@index([keyId])
  @@index([expiresAt, status])
  @@map("signing_sessions")
}

// Issued letters - stores issued letter records
model IssuedLetter {
  id              BigInt     @id @default(autoincrement()) @db.BigInt
  publicId        String?    @unique @default(cuid()) @map("public_id")
  submissionId    BigInt     @unique @map("submission_id") @db.BigInt
  letterNumber    String     @unique @map("letter_number") @db.VarChar(100)
  verificationCode String    @unique @map("verification_code") @db.VarChar(50)
  type            SubmissionType
  keterangan      String?    @db.Text // Admin description/notes about the letter
  
  // PAdES signing metadata
  signedBy        BigInt     @map("signed_by") @db.BigInt
  signatureKeyId  BigInt?    @map("signature_key_id") @db.BigInt
  signedAt        DateTime?  @map("signed_at")
  
  // File paths
  pdfPath         String     @map("pdf_path") @db.VarChar(255)
  
  // Metadata
  issuedAt        DateTime   @default(now()) @map("issued_at")
  expiresAt       DateTime?  @map("expires_at")
  isRevoked       Boolean    @default(false) @map("is_revoked")
  revokedAt       DateTime?  @map("revoked_at")
  revokedReason   String?    @map("revoked_reason") @db.Text
  
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  // Relations
  submission      Submission @relation(fields: [submissionId], references: [id])
  signatureKey    LurahKey?  @relation("IssuedLetterSignatureKey", fields: [signatureKeyId], references: [id])

  @@index([signatureKeyId])
  @@map("issued_letters")
}

// Atomic per-type per-year sequence counter for letter numbers
model LetterCounter {
  letterType String @map("letter_type")
  year       Int
  sequence   Int    @default(0)

  @@id([letterType, year])
  @@map("letter_counters")
}

// Verification attempt audit log
model VerificationLog {
  id               BigInt   @id @default(autoincrement()) @db.BigInt
  verificationCode String?  @map("verification_code")
  decisionStatus   String   @map("decision_status")
  serverPass       Boolean  @map("server_pass")
  cryptoPass       Boolean  @map("crypto_pass")
  documentPass     Boolean  @map("document_pass")
  attemptedAt      DateTime @default(now()) @map("attempted_at")

  @@map("verification_logs")
  @@index([verificationCode])
  @@index([attemptedAt])
}

enum NotificationType {
  submission
  announcement
  other
}

// User notification inbox
model Notification {
  id        BigInt    @id @default(autoincrement()) @db.BigInt
  userId    BigInt    @map("user_id") @db.BigInt
  type      NotificationType @default(other)
  title     String    @db.VarChar(255)
  body      String    @db.Text
  data      Json?     @db.Json
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

// ==================== ARSIP SURAT (External / Manual Letter Archive) ====================
// Standalone module for letters created/received OUTSIDE the citizen submission flow
// (surat masuk / surat keluar). The unified log view also reads IssuedLetter at query
// time, so this table never duplicates system-generated letters.

enum ArsipDirection {
  masuk
  keluar
}

enum ArsipSifat {
  biasa
  penting
  segera
  rahasia
}

model ArsipSurat {
  id              BigInt         @id @default(autoincrement()) @db.BigInt
  direction       ArsipDirection
  nomorSurat      String         @map("nomor_surat") @db.VarChar(100)
  tanggalSurat    DateTime       @map("tanggal_surat") @db.Date
  tanggalDiterima DateTime?      @map("tanggal_diterima") @db.Date
  pihak           String         @db.VarChar(150)
  perihal         String         @db.VarChar(255)
  sifat           ArsipSifat     @default(biasa)
  keterangan      String?        @db.Text
  filePath        String?        @map("file_path") @db.VarChar(255)
  fileType        String?        @map("file_type") @db.VarChar(50)
  createdById     BigInt         @map("created_by") @db.BigInt
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Relations
  createdBy       User           @relation(fields: [createdById], references: [id])

  @@index([direction])
  @@index([tanggalSurat])
  @@index([createdById])
  @@map("arsip_surat")
}
