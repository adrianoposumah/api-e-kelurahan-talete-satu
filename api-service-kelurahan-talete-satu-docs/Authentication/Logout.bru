meta {
  name: Logout
  type: http
  seq: 4
}

post {
  url: {{url}}/v1/auth/logout
  body: json
  auth: inherit
}

body:json {
  {
      "refresh_token": "{{refresh_token}}"
  }
}

script:post-response {
  const data = res.body;
  
  bru.setEnvVar("access_token", data.access_token);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
